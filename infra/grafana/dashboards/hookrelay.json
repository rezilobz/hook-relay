{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    }
  ],
  "title": "HookRelay",
  "uid": "hookrelay-v01",
  "description": "Delivery engine overview: ingestion rate, delivery outcomes, latency, retries, DLQ depth, and Kafka consumer lag.",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "tags": [
    "hookrelay"
  ],
  "panels": [
    {
      "id": 1,
      "title": "Events Ingested / s",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "hookrelay-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "hookrelay-prometheus"
          },
          "expr": "rate(hookrelay_events_ingested_total{job=\"hookrelay-api\"}[2m])",
          "legendFormat": "ingested/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Delivery Attempts / s by Outcome",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "hookrelay-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "fillOpacity": 10
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "success"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "failure"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "timeout"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "orange",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "hookrelay-prometheus"
          },
          "expr": "rate(hookrelay_deliveries_attempted_total{job=\"hookrelay-worker\"}[2m])",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Delivery Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "hookrelay-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "hookrelay-prometheus"
          },
          "expr": "histogram_quantile(0.50, rate(hookrelay_delivery_latency_seconds_bucket{job=\"hookrelay-worker\"}[5m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "hookrelay-prometheus"
          },
          "expr": "histogram_quantile(0.95, rate(hookrelay_delivery_latency_seconds_bucket{job=\"hookrelay-worker\"}[5m]))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "hookrelay-prometheus"
          },
          "expr": "histogram_quantile(0.99, rate(hookrelay_delivery_latency_seconds_bucket{job=\"hookrelay-worker\"}[5m]))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 4,
      "title": "Retry Depth at Success",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "hookrelay-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "hookrelay-prometheus"
          },
          "expr": "rate(hookrelay_retry_depth_sum{job=\"hookrelay-worker\"}[5m]) / rate(hookrelay_retry_depth_count{job=\"hookrelay-worker\"}[5m]) > 0",
          "legendFormat": "mean attempt",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "hookrelay-prometheus"
          },
          "expr": "rate(hookrelay_retry_depth_count{job=\"hookrelay-worker\"}[5m])",
          "legendFormat": "successes/s",
          "refId": "B"
        }
      ]
    },
    {
      "id": 5,
      "title": "DLQ Depth",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "hookrelay-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 16
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 10
              },
              {
                "color": "red",
                "value": 100
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "hookrelay-prometheus"
          },
          "expr": "hookrelay_dlq_entries_total{job=\"hookrelay-worker\"}",
          "legendFormat": "DLQ entries",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Kafka Consumer Lag",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "hookrelay-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 16,
        "x": 8,
        "y": 16
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 100
              },
              {
                "color": "red",
                "value": 1000
              }
            ]
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "hookrelay-prometheus"
          },
          "expr": "hookrelay_kafka_consumer_lag{job=\"hookrelay-worker\"}",
          "legendFormat": "{{topic}} p{{partition}}",
          "refId": "A"
        }
      ]
    }
  ]
}
