# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://hookrelay:hookrelay@localhost:5432/hookrelay

# ─── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_PENDING=hookrelay.events.pending
KAFKA_TOPIC_RETRY=hookrelay.events.retry
KAFKA_TOPIC_DLQ=hookrelay.events.dlq
KAFKA_CONSUMER_GROUP=hookrelay-workers

# ─── Worker ───────────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=10
MAX_RETRY_ATTEMPTS=9
DELIVERY_TIMEOUT_SECONDS=10

# ─── Security ─────────────────────────────────────────────────────────────────
SIGNATURE_HEADER=X-HookRelay-Signature
API_KEY_HEADER=X-API-Key
# API_KEYS=key1,key2,key3   # comma-separated list of valid API keys (required in production)

# ─── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# ─── PostgreSQL Docker service (used by docker-compose.yml) ───────────────────
POSTGRES_USER=hookrelay
POSTGRES_PASSWORD=hookrelay
POSTGRES_DB=hookrelay

# ─── Grafana (used by docker-compose.yml) ─────────────────────────────────────
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
